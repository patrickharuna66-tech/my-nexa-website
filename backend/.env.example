# NEXAHOST ENVIRONMENT — copy to .env and fill values

PORT=5000
NODE_ENV=production
FRONTEND_URL=https://yourdomain.com

DB_HOST=localhost
DB_PORT=5432
DB_NAME=nexahost
DB_USER=nexahost_user
DB_PASSWORD=your_strong_db_password

JWT_SECRET=replace_with_64_char_random_string
JWT_EXPIRES_IN=7d

WHM_HOST=https://your-server.inmotionhosting.com:2087
WHM_USER=your_whm_reseller_username
WHM_TOKEN=your_whm_api_token

SMTP_HOST=smtp.mailgun.org
SMTP_PORT=587
SMTP_USER=postmaster@yourdomain.com
SMTP_PASS=your_smtp_password
EMAIL_FROM="NexaHost <support@yourdomain.com>"

STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

FLUTTERWAVE_SECRET_KEY=FLWSECK_LIVE-xxx
FLUTTERWAVE_PUBLIC_KEY=FLWPUBK_LIVE-xxx
FLUTTERWAVE_WEBHOOK_SECRET=your_flw_webhook_secret

BCRYPT_ROUNDS=12
TRIAL_DAYS=30
